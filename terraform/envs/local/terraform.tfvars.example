keycloak_url       = "http://localhost:8080"
keycloak_client_id = "admin-cli"
keycloak_username  = "admin"
keycloak_password  = "replace-me"

# Alternative for a confidential provisioning client:
# keycloak_client_id     = "terraform-admin"
# keycloak_client_secret = "replace-me"

realm_name   = "demo"
display_name = "Demo Realm"

smtp = {
  host              = "smtp.example.com"
  port              = 587
  from              = "noreply@example.com"
  from_display_name = "IAM"
  reply_to          = "helpdesk@example.com"
  reply_to_display_name = "IAM Helpdesk"
  envelope_from     = "bounce@example.com"
  ssl               = false
  starttls          = true
  auth_username     = "smtp-user"
  auth_password     = "smtp-password"
}

themes = {
  login_theme   = "keycloak"
  account_theme = "keycloak.v3"
  admin_theme   = "keycloak.v2"
  email_theme   = "keycloak"
}

localization = {
  supported_locales = ["de", "en"]
  default_locale    = "de"
}

security_headers = {
  x_frame_options           = "SAMEORIGIN"
  content_security_policy   = "frame-src 'self'; frame-ancestors 'self'; object-src 'none';"
  x_content_type_options    = "nosniff"
  x_xss_protection          = "1; mode=block"
  strict_transport_security = "max-age=31536000; includeSubDomains"
  referrer_policy           = "no-referrer"
}

password_policy = "length(12) and digits(1) and upperCase(1) and lowerCase(1) and specialChars(1) and notUsername(undefined)"

token_settings = {
  access_code_lifespan_login               = "30m"
  access_token_lifespan                    = "15m"
  access_token_lifespan_for_implicit_flow  = "15m"
  action_token_generated_by_admin_lifespan = "12h"
  action_token_generated_by_user_lifespan  = "5m"
}

session_settings = {
  sso_session_idle_timeout             = "10h"
  sso_session_max_lifespan             = "30h"
  sso_session_idle_timeout_remember_me = "720h"
  sso_session_max_lifespan_remember_me = "1440h"
  client_session_idle_timeout          = "10h"
  client_session_max_lifespan          = "30h"
  offline_session_idle_timeout         = "720h"
  offline_session_max_lifespan_enabled = true
  offline_session_max_lifespan         = "1440h"
}

brute_force = {
  permanent_lockout                = false
  max_login_failures               = 5
  wait_increment_seconds           = 60
  quick_login_check_milli_seconds  = 1000
  minimum_quick_login_wait_seconds = 60
  max_failure_wait_seconds         = 900
  failure_reset_time_seconds       = 43200
}

login_settings = {
  registration_allowed           = false
  registration_email_as_username = false
  remember_me                    = true
  verify_email                   = true
  login_with_email_allowed       = true
  duplicate_emails_allowed       = false
  reset_password_allowed         = true
  edit_username_allowed          = false
}

otp_policy = {
  type              = "totp"
  algorithm         = "HmacSHA1"
  initial_counter   = 0
  digits            = 6
  look_ahead_window = 1
  period            = 30
  code_reusable     = false
}

webauthn = {
  rp_entity_name                    = "Example IAM"
  rp_id                             = "sso.example.com"
  signature_algorithms              = ["ES256", "RS256"]
  attestation_conveyance_preference = "not specified"
  authenticator_attachment          = "not specified"
  require_resident_key              = "not specified"
  user_verification_requirement     = "preferred"
  create_timeout                    = 0
  avoid_same_authenticator_register = false
  acceptable_aaguids                = []
}

webauthn_passwordless = {
  rp_entity_name                    = "Example IAM"
  rp_id                             = "sso.example.com"
  signature_algorithms              = ["ES256", "RS256"]
  attestation_conveyance_preference = "not specified"
  authenticator_attachment          = "not specified"
  require_resident_key              = "Yes"
  user_verification_requirement     = "required"
  create_timeout                    = 0
  avoid_same_authenticator_register = false
  acceptable_aaguids                = []
}

event_settings = {
  admin_events_enabled         = true
  admin_events_details_enabled = true
  events_enabled               = true
  enabled_event_types          = ["LOGIN", "LOGOUT", "REGISTER", "UPDATE_PASSWORD"]
  events_expiration            = 2592000
  events_listeners             = ["jboss-logging"]
}

realm_attributes = {
  "frontendUrl" = "https://sso.example.com"
}

components = []
organizations = []
verifiable_credentials = {
  enabled   = false
  format    = ""
  algorithm = ""
  extra     = {}
}

default_realm_roles = ["viewer"]

roles = {
  admin = { description = "Realm administrator" }
  viewer = { description = "Read-only access" }
  developer = { description = "Developer access" }
}

groups = {
  admins = {
    realm_roles = ["admin"]
  }
  developers = {
    realm_roles = ["developer", "viewer"]
    attributes = {
      team = ["platform"]
    }
  }
}

users = {
  "max.mustermann" = {
    email          = "max.mustermann@example.com"
    first_name     = "Max"
    last_name      = "Mustermann"
    enabled        = true
    email_verified = true
    groups         = ["developers"]
    attributes     = { department = ["engineering"] }
    initial_password = {
      value     = "ChangeMe123!"
      temporary = true
    }
  }
}

clients = {
  bearer_only = {
    api = {
      client_id     = "demo-api"
      name          = "Demo API"
      client_secret = "replace-me-bearer-only"
      extra_config = {
        "access.token.header.type.rfc9068" = "true"
      }
    }
  }

  confidential = {
    backend = {
      client_id           = "demo-backend"
      name                = "Demo Backend"
      client_secret       = "replace-me-confidential"
      root_url            = "https://backend.example.com"
      valid_redirect_uris = ["https://backend.example.com/*"]
      web_origins         = ["https://backend.example.com"]
      valid_post_logout_redirect_uris = ["https://backend.example.com/*"]
      roles = {
        user = {
          description = "Backend application user role"
        }
      }
    }
  }

  public = {
    spa = {
      client_id           = "demo-spa"
      name                = "Demo SPA"
      root_url            = "https://app.example.com"
      valid_redirect_uris = ["https://app.example.com/*"]
      web_origins         = ["https://app.example.com"]
      valid_post_logout_redirect_uris = ["https://app.example.com/*"]
      scope_mappings = {
        realm_roles = ["viewer"]
      }
      protocol_mappers = {
        tenant = {
          protocol_mapper = "oidc-hardcoded-claim-mapper"
          config = {
            "claim.name"           = "tenant"
            "claim.value"          = "demo"
            "jsonType.label"       = "String"
            "id.token.claim"       = "true"
            "access.token.claim"   = "true"
            "userinfo.token.claim" = "true"
          }
        }
      }
    }
  }

  service_account = {
    job = {
      client_id      = "demo-job"
      name           = "Demo Job"
      client_secret  = "replace-me-service-account"
      roles = {
        executor = {
          name        = "job-executor"
          description = "Allows running background jobs"
        }
      }
      service_account_roles = {
        realm_roles = ["viewer"]
        client_roles = [
          {
            client_type = "service_account"
            client_key  = "job"
            role_key    = "executor"
          }
        ]
      }
      extra_config = {
        "access.token.header.type.rfc9068" = "true"
      }
    }
  }
}

ldap_federation = {
  enabled                 = false
  name                    = "corp-ldap"
  username_ldap_attribute = "uid"
  rdn_ldap_attribute      = "cn"
  uuid_ldap_attribute     = "entryUUID"
  user_object_classes     = ["inetOrgPerson", "organizationalPerson"]
  connection_url          = "ldap://ldap.example.com:389"
  users_dn                = "ou=users,dc=example,dc=com"
  bind_dn                 = "cn=admin,dc=example,dc=com"
  bind_credential         = "replace-me"
  auth_type               = "simple"
  vendor                  = "other"
  edit_mode               = "READ_ONLY"
  import_enabled          = true
  sync_registrations      = false
  trust_email             = true
  connection_timeout      = "5000"
  read_timeout            = "10000"
  pagination              = true
  mappers = [
    {
      name                        = "email"
      user_model_attribute        = "email"
      ldap_attribute              = "mail"
      read_only                   = true
      always_read_value_from_ldap = true
    },
    {
      name                        = "first-name"
      user_model_attribute        = "firstName"
      ldap_attribute              = "givenName"
      read_only                   = true
      always_read_value_from_ldap = true
    },
    {
      name                        = "last-name"
      user_model_attribute        = "lastName"
      ldap_attribute              = "sn"
      read_only                   = true
      always_read_value_from_ldap = true
    },
    {
      name                        = "display-name"
      user_model_attribute        = "displayName"
      ldap_attribute              = "displayName"
      read_only                   = true
      always_read_value_from_ldap = true
    }
  ]
}

google_identity_provider = {
  enabled        = false
  alias          = "google"
  display_name   = "Google"
  client_id      = ""
  client_secret  = ""
  default_scopes = "openid email profile"
  mappers = [
    {
      name           = "email"
      claim          = "email"
      user_attribute = "email"
      sync_mode      = "INHERIT"
    },
    {
      name           = "first-name"
      claim          = "given_name"
      user_attribute = "firstName"
      sync_mode      = "INHERIT"
    },
    {
      name           = "last-name"
      claim          = "family_name"
      user_attribute = "lastName"
      sync_mode      = "INHERIT"
    },
    {
      name           = "locale"
      claim          = "locale"
      user_attribute = "locale"
      sync_mode      = "INHERIT"
    },
    {
      name           = "picture"
      claim          = "picture"
      user_attribute = "picture"
      sync_mode      = "INHERIT"
    },
    {
      name           = "google-sub"
      claim          = "sub"
      user_attribute = "google_sub"
      sync_mode      = "INHERIT"
    }
  ]
  username_template = {
    enabled   = true
    template  = "$${ALIAS}.$${CLAIM.sub | lowercase}"
    target    = "LOCAL"
    sync_mode = "INHERIT"
  }
}

azuread_identity_provider = {
  enabled        = false
  alias          = "azuread"
  display_name   = "Azure AD"
  tenant_id      = ""
  client_id      = ""
  client_secret  = ""
  default_scopes = "openid profile email"
  mappers = [
    {
      name           = "email"
      claim          = "email"
      user_attribute = "email"
      sync_mode      = "INHERIT"
    },
    {
      name           = "first-name"
      claim          = "given_name"
      user_attribute = "firstName"
      sync_mode      = "INHERIT"
    },
    {
      name           = "last-name"
      claim          = "family_name"
      user_attribute = "lastName"
      sync_mode      = "INHERIT"
    },
    {
      name           = "display-name"
      claim          = "name"
      user_attribute = "displayName"
      sync_mode      = "INHERIT"
    },
    {
      name           = "preferred-username"
      claim          = "preferred_username"
      user_attribute = "azuread_preferred_username"
      sync_mode      = "INHERIT"
    },
    {
      name           = "object-id"
      claim          = "oid"
      user_attribute = "azuread_object_id"
      sync_mode      = "INHERIT"
    },
    {
      name           = "tenant-id"
      claim          = "tid"
      user_attribute = "azuread_tenant_id"
      sync_mode      = "INHERIT"
    }
  ]
  username_template = {
    enabled   = true
    template  = "$${ALIAS}.$${CLAIM.oid | lowercase}"
    target    = "LOCAL"
    sync_mode = "INHERIT"
  }
}

apple_identity_provider = {
  enabled        = false
  alias          = "apple"
  display_name   = "Apple"
  client_id      = ""
  client_secret  = ""
  default_scopes = "name email"
  mappers = [
    {
      name           = "email"
      claim          = "email"
      user_attribute = "email"
      sync_mode      = "INHERIT"
    },
    {
      name           = "apple-sub"
      claim          = "sub"
      user_attribute = "apple_sub"
      sync_mode      = "INHERIT"
    },
    {
      name           = "email-verified"
      claim          = "email_verified"
      user_attribute = "apple_email_verified"
      sync_mode      = "INHERIT"
    },
    {
      name           = "private-email"
      claim          = "is_private_email"
      user_attribute = "apple_private_email"
      sync_mode      = "INHERIT"
    }
  ]
  username_template = {
    enabled   = true
    template  = "$${ALIAS}.$${CLAIM.sub | lowercase}"
    target    = "LOCAL"
    sync_mode = "INHERIT"
  }
}
